generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["auth", "user_management"]
}

enum Role {
  admin
  user
  @@schema("auth")
}

enum OtpType {
  registration
  forgot_password
  change_email
  change_password
  account_deletion
  @@schema("auth")
}

enum gender {
  male
  female
  @@schema("user_management")
}

model User {
  id                 String           @id @default(uuid()) @db.Uuid
  username           String           @unique @db.VarChar(100)
  email              String           @unique @db.VarChar(100)
  password           String?          @db.VarChar(100)
  role               Role             @default(user)
  provider           String           @default("local") @db.VarChar(20)
  provider_id        String?          @db.VarChar(100)
  is_verified        Boolean          @default(false)
  is_active          Boolean          @default(true)
  deletion_requested Boolean          @default(false)
  created_at         DateTime         @default(now()) @db.Timestamp(0)
  updated_at         DateTime         @default(now()) @updatedAt @db.Timestamp(0)
  deleted_at         DateTime?        @db.Timestamp(0)

  profile            ProfileUser?
  otp_logs           OtpLog[]
  password_resets    PasswordReset[]

  @@map("users")
  @@schema("auth")
}

model ProfileUser {
  id            String    @id @default(uuid()) @db.Uuid
  user_id       String    @unique @db.Uuid
  full_name     String?   @db.VarChar(255)
  phone         String?   @db.VarChar(20)
  birth_date    DateTime? @db.Date
  gender        gender?
  profile_image String?   @db.Text
  created_at    DateTime  @default(now()) @db.Timestamp(0)
  updated_at    DateTime  @default(now()) @updatedAt @db.Timestamp(0)
  deleted_at    DateTime? @db.Timestamp(0)
  user          User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("profile_users")
  @@schema("user_management")
}

model OtpLog {
  id            String    @id @default(uuid()) @db.Uuid
  user_id       String    @db.Uuid
  otp_code      String    @db.VarChar(10)
  type          OtpType
  target        String    @db.VarChar(100)
  expired_at    DateTime  @db.Timestamp(0)
  is_used       Boolean   @default(false)
  attempt_count Int       @default(0)
  created_at    DateTime  @default(now()) @db.Timestamp(0)
  user          User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("otp_logs")
  @@schema("auth")
}

model PasswordReset {
  id         String    @id @default(uuid()) @db.Uuid
  user_id    String    @db.Uuid
  token      String    @unique @db.Text
  is_used    Boolean   @default(false)
  expired_at DateTime  @db.Timestamp(0)
  created_at DateTime  @default(now()) @db.Timestamp(0)
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("password_resets")
  @@schema("auth")
}

model TaskManagement {
  id         String    @id @default(uuid()) @db.Uuid
  user_id    String    @db.Uuid
  title      String    @unique @db.Text
  deadline   DateTime  @db.Timestamp(0)
  status     String    @db.VarChar(100)
  created_at DateTime  @default(now()) @db.Timestamp(0)
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("password_resets")
  @@schema("auth")
}